{
	"layer": "top",
	"position": "top",
	"height": 33,

	"modules-left": ["group/left"],

	"modules-center": ["group/center"],

	"modules-right": ["group/right"],

	"group/center": {
		"orientation": "horizontal",
		"modules": [
			"bluetooth", 
			"clock", 
			"custom/weather",
			"custom/usb"
		]
	},

	"group/left": {
		"orientation": "horizontal",
		"modules": [
			"hyprland/workspaces", 
			// "mpris",
			"custom/cava",
			"custom/github-commits",
			"custom/gcal-calendar"
		]
	},

	"group/right": {
		"orientation": "horizontal",
		"modules": ["custom/vpn", "pulseaudio", "network", "battery", "custom/power"]
	},

	"hyprland/workspaces": {
		"format": "{windows}",
		"window-rewrite-default": " у°Ё• ",
		"window-rewrite": {
			"title<.*youtube.*>": " п…Ә ", 
			"class<zen> title<calendar.notion.so>": " пҒі ",
			"title<.*openai.*>": " уұ ғ ", 
			"class<zen> title<.*github.*>": " п„“ ", 
			"class<zen>": " пү« ", 
			"title<.*nvim.*>": " у°ҳ¬ ",
			"title<OC \\|.*>": " оЎЎ ",
			"class<org.kde.dolphin>": " пҒј ",
			"class<dolphin>": " пҒј ",
			"class<nautilus>": " пҒј ",
			"class<org.gnome.Nautilus>": " пҒј ",
			"kitty": " пҮӢ ", 
			"spotify": " пҶј ",
			"signal": " пҲІ ",
			"steam": " пҶ· ",
			"discord": " у°ҷҜ "
		}
	},


	"pulseaudio": {
		"format": " у°Ҙӣ {volume}%",
		"tooltip": false
	},

	"network": {
		"format": "пӮһ  {essid}: {signalStrength}%",
		"on-click": "~/.config/waybar/scripts/rofi-network.sh"
	},

	"clock": {
		"format": "  {:%H:%M}  ",
		"format-alt": "  {:%d %b %Y %H:%M:%S}  ",
		"tooltip": false,
		"interval": 1
	},

	"battery": {
		"format": "пғ§ {capacity}%"
	},

	"custom/power": {
		"exec": "echo п…Һ",
		"format": " {}  ",
		"tooltip": false,
		"on-click": "~/.config/waybar/scripts/rofi-power.sh"
	},

	"custom/usb": {
		"exec": "~/.config/waybar/scripts/usb-devices.sh",
		"return-type": "json",
		"interval": 1,
		"format": " {}  "
	},

	"custom/vpn": {
		"interval": 3600,
		"exec": "sh -c \"nordvpn status | awk -F': ' '/^Status:/ {s=\\$2} /^Country:/ {c=\\$2} /^City:/ {y=\\$2} END {if (s==\\\"Disconnected\\\") print \\\"Disconnected\\\"; else print c \\\", \\\" y}'\"",
		"format": " у°ҡҢ {} ",
		"on-click": "~/.config/waybar/scripts/rofi-vpn.sh",
		"tooltip": false
	},

	"custom/weather": {
  "exec": "curl -s 'wttr.in/?format=1' | sed 's/ \\{2,\\}/ /g'",
		"tooltip": false,
		"interval": 100,
		"format": " {} "
	},

	"custom/cava": {
		"exec": "~/.config/waybar/scripts/cava-rendering.sh",
		"restart-interval": 2,
		"tooltip": false,
		"tail": true,
		"format": " {} ",
		"return-type": "text",
		"on-click": "playerctl play-pause"
	},

	"mpris": {
		"format": " {player_icon}  {dynamic} ",
		"format-paused": " {status_icon} {dynamic} ",
		"format-stopped": "",
		"ignore-list": ["vesktop"],
		"player-icons": {
			"default": "у°ҺҮ",
			"spotify": "пҶј",
			"vlc": "пҖҪ",
			"mpv": "п…„"
		},
		"status-icons": {
			"paused": "пҒӢ",
			"playing": "вҸё"
		},
		"interval": 1,
		"dynamic-order":  ["artist", "title", "position", "length"] ,
		"album-len": 0,
		"title-len": 20,
		"max-length": 40,
		"tooltip": true
	},

	"custom/github-commits": {
		"format": "{}",
		"return-type": "json",
		"exec": "~/.config/waybar/scripts/github-commits.sh",
		"on-click": "zen-browser github.com/KingerNL",
		"interval": 660,
		"tooltip": false
	},

	"custom/gcal-calendar": {
    "exec": "~/.config/waybar/scripts/gcal-next-event.py",
    "format": " {} ",
    "return-type": "json",
    "interval": 300,
    "tooltip": true
	},

	"bluetooth": {
		"format": " пҠ” {status}  ",
		"format-disabled": "", // an empty format will hide the module
		"format-connected": " пҠ” {num_connections} connected  ",
		"tooltip-format": " {controller_alias}\t{controller_address} ",
		"tooltip-format-connected": "{controller_alias}\t{controller_address}\n\n{device_enumerate}",
		"tooltip-format-enumerate-connected": "{device_alias}\t{device_address}",
		"on-click": "~/.config/waybar/scripts/rofi-bluetooth.sh"
	}
}
