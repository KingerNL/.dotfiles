{
	"layer": "top",
	"position": "top",
	"height": 33,

	"modules-left": ["group/left"],

	"modules-center": ["group/center"],

	"modules-right": ["group/right"],

	"group/center": {
		"orientation": "horizontal",
		"modules": [
			"bluetooth", 
			"clock", 
			"custom/weather",
			"custom/usb",
			"custom/eww-background"
		]
	},

	"group/left": {
		"orientation": "horizontal",
		"modules": [
			"hyprland/workspaces", 
			// "mpris",
			"custom/cava",
			"custom/github-commits",
			"custom/gcal-calendar"
			// "image#album-art"
		]
	},

	"group/right": {
		"orientation": "horizontal",
		"modules": ["custom/vpn", "pulseaudio", "custom/network", "custom/battery", "custom/power"]
	},

	"hyprland/workspaces": {
		"format": "{windows}",
		"window-rewrite-default": " 󰨕 ",
		"window-rewrite": {
			"title<.*youtube.*>": "  ", 
			"class<zen> title<calendar.notion.so>": "  ",
			"title<.*openai.*>": " 󱠃 ", 
			"class<zen> title<.*github.*>": "  ", 
			"class<zen>": "  ", 
			"title<.*nvim.*>": " 󰘬 ",
			"title<OC \\|.*>": "  ",
			"class<org.kde.dolphin>": "  ",
			"class<dolphin>": "  ",
			"class<nautilus>": "  ",
			"class<org.gnome.Nautilus>": "  ",
			"kitty": "  ", 
			"spotify": "  ",
			"signal": "  ",
			"steam": "  ",
			"discord": " 󰙯 "
		}
	},


	"pulseaudio": {
		"format": " 󰥛 {volume}%",
		"tooltip": false
	},

	"custom/network": {
		"exec": "~/.config/waybar/scripts/network-status.sh",
		"format": "{}",
		"return-type": "json",
		"tooltip": true,
		"interval": 2,
		"on-click": "~/.config/waybar/scripts/rofi-network.sh",
		"on-click-right": "~/.config/waybar/scripts/robot-eth.sh toggle"
	},

	"clock": {
		"format": "  {:%H:%M}  ",
		"format-alt": "  {:%d %b %Y %H:%M:%S}  ",
		"tooltip": false,
		"interval": 1
	},

	"custom/battery": {
		"exec": "~/.config/waybar/scripts/battery-status.sh",
		"return-type": "json",
		"interval": 10,
		"format": "{}",
		"tooltip": true,
		"escape": false
	},

	"custom/power": {
		"exec": "echo ",
		"format": " {}  ",
		"tooltip": false,
		"on-click": "~/.config/waybar/scripts/rofi-power.sh"
	},

	"custom/usb": {
		"exec": "~/.config/waybar/scripts/usb-devices.sh",
		"return-type": "json",
		"interval": 5,
		"format": "{}"
	},

	"custom/eww-background": {
		"exec": "~/.config/waybar/scripts/eww-background-toggle.sh status",
		"return-type": "json",
		"interval": 2,
		"format": " {} ",
		"tooltip": true,
		"on-click": "~/.config/waybar/scripts/eww-background-toggle.sh toggle",
		"on-click-right": "~/.config/waybar/scripts/eww-background-toggle.sh reload"
	},

	"custom/vpn": {
		"interval": 3600,
		"exec": "sh -c \"nordvpn status | awk -F': ' '/^Status:/ {s=\\$2} /^Country:/ {c=\\$2} /^City:/ {y=\\$2} END {if (s==\\\"Disconnected\\\") print \\\"Disconnected\\\"; else print c \\\", \\\" y}'\"",
		"format": " 󰚌 {} ",
		"on-click": "~/.config/waybar/scripts/rofi-vpn.sh",
		"tooltip": false
	},

	"custom/weather": {
  "exec": "curl -s 'wttr.in/?format=1' | sed 's/ \\{2,\\}/ /g'",
		"tooltip": false,
		"interval": 100,
		"format": " {} "
	},

	"custom/gcal-calendar": {
    "exec": "~/.config/waybar/scripts/gcal-next-event.py",
    "format": " {} ",
    "return-type": "json",
    "interval": 300,
    "tooltip": true
	},

	"custom/cava": {
		"exec": "~/.config/waybar/scripts/cava-rendering.sh",
		"restart-interval": 2,
		"tooltip": false,
		"tail": true,
		"format": " {} ",
		"return-type": "text",
		"on-click": "playerctl play-pause"
	},

	"mpris": {
		"format": " {player_icon}  {dynamic} ",
		"format-paused": " {status_icon} {dynamic} ",
		"format-stopped": "",
		"ignore-list": ["vesktop"],
		"player-icons": {
			"default": "󰎇",
			"spotify": "",
			"vlc": "",
			"mpv": ""
		},
		"status-icons": {
			"paused": "",
			"playing": "⏸"
		},
		"interval": 1,
		"dynamic-order":  ["artist", "title", "position", "length"] ,
		"album-len": 0,
		"title-len": 20,
		"max-length": 40,
		"tooltip": true
	},

	"custom/github-commits": {
		"format": "{}",
		"return-type": "json",
		"exec": "~/.config/waybar/scripts/github-commits.sh",
		"on-click": "zen-browser github.com/KingerNL",
		"interval": 660,
		"tooltip": false
	},

	"bluetooth": {
		"format": "  {status}  ",
		"format-disabled": "", // an empty format will hide the module
		"format-connected": "  {num_connections} connected  ",
		"tooltip-format": " {controller_alias}\t{controller_address} ",
		"tooltip-format-connected": "{controller_alias}\t{controller_address}\n\n{device_enumerate}",
		"tooltip-format-enumerate-connected": "{device_alias}\t{device_address}",
		"on-click": "~/.config/waybar/scripts/rofi-bluetooth.sh"
	}

	// "image#album-art": {
	// 	"path": "/home/murt/Pictures/test.jpg",
	// 	"interval": 5
	// }
}
