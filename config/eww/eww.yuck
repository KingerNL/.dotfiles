(defpoll DNA_FRAME
  :interval "90ms"
  :initial ""
  "~/.config/eww/widgets/dna/dna-frame.sh")

(defpoll BRAIN_FRAME
  :interval "60ms"
  :initial ""
  "~/.config/eww/widgets/brain-robot/brain-frame.sh")

(defpoll PROC_RADAR
  :interval "1s"
  :initial ""
  "~/.config/eww/widgets/process-radar/proc-radar.sh")

(defpoll PROC_RADAR_MODE
  :interval "1s"
  :initial "CPU"
  "~/.config/eww/widgets/process-radar/proc-radar-mode.sh")

(defpoll ROBOT_LINK
  :interval "1s"
  :initial "ROBOT LINK"
  "~/.config/eww/widgets/brain-robot/robot-link.sh")

(defpoll PROMPT_AGENT_FRAME
  :interval "40ms"
  :initial ""
  "~/.config/eww/widgets/prompt-agent/prompt-agent-frame.sh")

(defpoll PROMPT_AGENT_STATE
  :interval "250ms"
  :initial "IDLE"
  "~/.config/eww/widgets/prompt-agent/prompt-agent-state.sh")

(defpoll PROMPT_AGENT_RESPONSE
  :interval "250ms"
  :initial "Ask the pig."
  "~/.config/eww/widgets/prompt-agent/prompt-agent-response.sh")

(defpoll PROMPT_AGENT_MODEL
  :interval "3600s"
  :initial "gpt-5.5"
  "~/.config/eww/widgets/prompt-agent/prompt-agent-model.sh")

(defvar PROMPT_AGENT_INPUT "")

(defwindow desktop-widget
  :monitor 0
  :geometry (geometry
    :x "0%"
    :y "0%"
    :width "100%"
    :height "100%"
    :anchor "center")
  :stacking "bottom"
  :exclusive false
  :focusable "ondemand"
  :namespace "desktop-widget"
  (overlay
    (box
      :class "desktop-root"
      :hexpand true
      :vexpand true)
    (box
      :halign "end"
      :valign "start"
      (box
        :class "dna-card"
        (overlay
          (label :class "dna-frame" :text DNA_FRAME)
          (box
            :class "proc-radar-card"
            :halign "center"
            :valign "center"
            :orientation "v"
            :space-evenly false
            (box
              :orientation "v"
              :space-evenly false
              (box
                :class "proc-radar-tabs"
                :space-evenly false
                :halign "center"
                :vexpand false
                (button
                  :class {PROC_RADAR_MODE == "CPU" ? "proc-radar-tab active" : "proc-radar-tab"}
                  :onclick "bash -lc '/home/murt/.config/eww/widgets/process-radar/proc-radar-toggle.sh cpu'"
                  "[CPU]")
                (button
                  :class {PROC_RADAR_MODE == "MEM" ? "proc-radar-tab active" : "proc-radar-tab"}
                  :onclick "bash -lc '/home/murt/.config/eww/widgets/process-radar/proc-radar-toggle.sh mem'"
                  "[MEM]"))
              (label
                :class "proc-radar-text"
                :vexpand false
                :text PROC_RADAR))))))
    (box
    :halign "end"
    :valign "center"
    (box
      :class "hippo-card"
      (overlay
        (label :class "brain-frame" :text BRAIN_FRAME)
        (box
          :class "robot-link-card"
          :halign "center"
          :valign "center"
          (label :class "robot-link-text" :text ROBOT_LINK)))))
    (box
      :halign "start"
      :valign "center"
      (box
        :class "prompt-agent-card"
        :orientation "v"
        :space-evenly false
        (box
          :class "prompt-agent-header"
          :space-evenly false
          (label
            :class "prompt-agent-model"
            :hexpand true
            :xalign 0
            :text PROMPT_AGENT_MODEL)
          (label
            :class "prompt-agent-character"
            :xalign 1
            :text "Pigma Dengar"))
        (label :class "prompt-agent-frame" :text PROMPT_AGENT_FRAME)
        (box
          :class "prompt-agent-status-row"
          :space-evenly false
          (label :class "prompt-agent-title" :text "STAR WOLF")
          (label :class "prompt-agent-state" :text PROMPT_AGENT_STATE))
        (input
          :class "prompt-agent-input"
          :value PROMPT_AGENT_INPUT
          :placeholder "ask pigma"
          :onaccept "bash -lc '/home/murt/.config/eww/widgets/prompt-agent/prompt-agent-submit.sh \"{}\"'")
        (label
          :class "prompt-agent-response"
          :xalign 0
          :text PROMPT_AGENT_RESPONSE)))))
